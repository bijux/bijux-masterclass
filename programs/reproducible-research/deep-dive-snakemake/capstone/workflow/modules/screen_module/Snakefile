# workflow/modules/screen_module/Snakefile
from __future__ import annotations

import os

PYTHONPATH = os.path.join(workflow.basedir, "src")

rule screen:
    input:
        kmer_json="kmer.json"
    output:
        json="screen.json"
    params:
        panel_fasta="panel.fasta",
        pythonpath=PYTHONPATH,
        benchdir=lambda wc: config["benchmarks_dir"],
    log:
        "screen.log"
    benchmark:
        "screen.txt"
    conda:
        config["_env_python"]
    shell:
        r"""
        set -euo pipefail

        mkdir -p "$(dirname {output.json})" "$(dirname {log})" "{params.benchdir}"

        PYTHONPATH="{params.pythonpath}" \
        python3 -m capstone.screen_panel \
            --sample-kmer-json "{input.kmer_json}" \
            --panel-fasta "{params.panel_fasta}" \
            --out-json "{output.json}" 2> "{log}"
        """
